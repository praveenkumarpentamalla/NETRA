{
  "name": "netra",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/*",
    "apps/*",
    "shared/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "flyway migrate",
    "db:seed": "ts-node database/seeds/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
